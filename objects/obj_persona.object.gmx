            <kind>1</kind>
            <string>var _audio = audio_sound_get_track_position(audio);
y = 120;

draw_set_valign(fa_center);
draw_set_halign(fa_middle);
draw_set_font(fnt_smol);
draw_set_colour(c_black);

if _audio &lt; 1.102
{
    x = 160;
    xscale=lerp(xscale,2,0.1);
    yscale=lerp(yscale,2,0.1);
    draw_text_transformed(x,y,"YOU'LL NEVER#SEE IT",xscale,yscale,0);
}
else
{
    played=1;
    draw_set_halign(fa_left);
    if _audio &lt; 1.530 x1=lerp(x1,140,0.2) else x1=lerp(x1,-60000,0.002);
    draw_text_transformed(x1,y,"",8,8,0);
}

if _audio==0 &amp;&amp; played=1
{
    obj_9_end.alarm[1]=1;
    instance_destroy();
}
</string>
