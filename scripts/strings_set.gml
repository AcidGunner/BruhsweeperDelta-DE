        global.str[9]="Сброс Игры";
        global.str[10]="ВНИМАНИЕ!!# #Это НОЧНАЯ Сборка. Некоторые вещи НЕ СТАБИЛЬНЫ. РЕКОМЕНДУЕТСЯ ИГРАТЬ НА ТЕКУЩЕЙ СТАБИЛЬНОЙ ВЕРСИИ.#ВЫ БЫЛИ ПРЕДУПРЕЖДЕНЫ!!"
